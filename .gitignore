data/castle2024/raw_dataset_index.csv

# ----- App local I/O -----
app/models/**
!app/models/**/.gitkeep
!app/models/**/README.md
app/inputs/**
!app/inputs/**/.gitkeep
!app/inputs/**/README.md
app/outputs/**
!app/outputs/README.md
!app/outputs/**/.gitkeep

# ----- Third-party clones: keep code if tracked, never weights/media -----
third_party/**/models/**
third_party/**/checkpoints/**
third_party/**/*.pt
third_party/**/*.pth
third_party/**/*.ckpt
third_party/**/*.onnx
third_party/**/*.safetensors
third_party/**/*.bin
third_party/**/my_dataset/**
third_party/**/assets/**/*.{jpg,jpeg,png,webp,gif}

# ----- InsightFace / HuggingFace / torch caches (user home paths not in repo,
#       but guard accidental copies into the tree) -----
**/.insightface/
**/huggingface/
**/hf_cache/
**/rfdetr_hf_cache/
**/rfdetr_download/

# ----- Experiment timing / local scratch -----
outputs/test_app_timing.json
**/tmp/
**/temp/
*.tmp

# Directory shells and documentation
!**/.gitkeep
!**/README.md
!docs/**/*.md
!app/docs/**/*.md
!outputs/**/*.md
!outputs/**/*.csv
!outputs/**/*.json
!outputs/**/*.jsonl
!outputs/**/*.txt
!outputs/**/*.tex
